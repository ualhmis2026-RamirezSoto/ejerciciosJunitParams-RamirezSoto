{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "gradle: build",
      "type": "shell",
      "command": "./gradlew${env:ComSpec && '.bat' || ''}",
      "args": ["build"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false
      }
    },
    {
      "label": "gradle: test",
      "type": "shell",
      "command": "./gradlew${env:ComSpec && '.bat' || ''}",
      "args": ["test"],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "focus": true
      }
    },
    {
      "label": "gradle: quickTest",
      "type": "shell",
      "command": "./gradlew${env:ComSpec && '.bat' || ''}",
      "args": ["quickTest"],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "gradle: jacocoTestReport",
      "type": "shell",
      "command": "./gradlew${env:ComSpec && '.bat' || ''}",
      "args": ["test", "jacocoTestReport"],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "focus": false
      }
    },
    {
      "label": "gradle: clean",
      "type": "shell",
      "command": "./gradlew${env:ComSpec && '.bat' || ''}",
      "args": ["clean"],
      "group": "build",
      "presentation": {
        "reveal": "always"
      }
    }
  ]
}
